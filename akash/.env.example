# Akash deployment environment variables. Copy to .env (gitignored) and fill.
# Used by akash/run_experiments.py (Console Managed Wallet API) and/or
# pasted into the Akash Console UI "Environment Variables" pane at deploy time.

# Akash Console Managed Wallet API key.
# Create at: console.akash.network → Settings → API Keys
# Grants full access to your Console account. Keep secret.
CONSOLE_API_KEY=

# Weights & Biases (required for online logging during the run).
# Get a key at https://wandb.ai/authorize
WANDB_API_KEY=

# Optional: override the W&B run group label per experiment phase.
# WANDB_RUN_GROUP=phase2A_calibration

# Hugging Face (only required if pulling a private TinyStories mirror).
# Public TinyStories does not require this.
# HF_TOKEN=

# Akash reputation defense weights (Phase 2C headline only).
# Comma-separated floats indexed [honest_0, honest_1, byzantine_0].
# AKASH_REP_REGIME=realistic
# AKASH_REP_WEIGHTS=0.85,0.85,0.30
